{
  "name": "free-ai-router",
  "version": "7.0.0",
  "description": "MCP server that routes chat completions across free-tier LLM providers with automatic fallback",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "bin": {
    "free-ai-router": "./index.js",
    "free-ai-router-http": "./http-server.js"
  },
  "files": [
    "index.js",
    "http-server.js",
    "lib",
    "providers",
    "templates",
    "scripts",
    "openapi.yaml",
    "README.md",
    "ROADMAP.md",
    "CHANGELOG.md",
    "LICENSE",
    ".env.example"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Irsyadmr354/free-ai-router.git"
  },
  "keywords": [
    "mcp",
    "llm",
    "router",
    "free-tier",
    "gemini",
    "groq",
    "openrouter",
    "fallback"
  ],
  "license": "MIT",
  "scripts": {
    "start": "node index.js",
    "start:http": "node http-server.js",
    "test": "node test-call.js",
    "check": "node scripts/check-syntax.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "17.4.2",
    "terser": "^5.49.0"
  }
}
