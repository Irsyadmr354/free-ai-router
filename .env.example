# ── Original three providers ─────────────────────────────────────────────────

# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Get from https://console.groq.com/keys
GROQ_API_KEY=

# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Additional providers ──────────────────────────────────────────────────────

# Get from https://dash.cloudflare.com/profile/api-tokens
# Also requires CLOUDFLARE_ACCOUNT_ID (find it on https://dash.cloudflare.com)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Get from https://cloud.sambanova.ai/apis
# ⚠️  WARNING: SambaNova is NOT fully free. $5 credit on signup expires in 3 months.
# After that, it becomes pay-per-use. Disabled by default to prevent surprise charges.
# Uncomment and fill in ONLY if you know your credit is still active.
# SAMBANOVA_API_KEY=

# Get from https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Get from https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# ── OpenCode Zen ────────────────────────────────────────────────────────────────

# Get from https://opencode.ai/settings/api-keys (free tier available)
# OpenAI-compatible gateway, provides free curated models for coding.
OPENCODE_API_KEY=

# ── Optional tuning ───────────────────────────────────────────────────────────

# Comma-separated fallback order (default shown below)
# PROVIDER_ORDER=gemini,groq,openrouter,cloudflare,sambanova,cohere,mistral

# Per-provider request timeouts in ms (default: 15000)
# TIMEOUT_GEMINI_MS=15000
# TIMEOUT_GROQ_MS=10000
# TIMEOUT_OPENROUTER_MS=15000
# TIMEOUT_CLOUDFLARE_MS=15000
# TIMEOUT_SAMBANOVA_MS=15000
# TIMEOUT_COHERE_MS=15000
# TIMEOUT_MISTRAL_MS=15000

# Rate-limit cooldown window in ms (default: 60000 = 60s)
# PROVIDER_COOLDOWN_MS=60000

# Response cache TTL in ms (default: 300000 = 5min). Set CACHE_ENABLED=false to disable.
# CACHE_TTL_MS=300000
# CACHE_ENABLED=true

# Usage log file path (default: ./usage-log.jsonl). Set USAGE_TRACKING=false to disable.
# USAGE_LOG_PATH=./usage-log.jsonl
# USAGE_TRACKING=true

# ── Notifications (optional) ──────────────────────────────────────────────────

# Discord webhook URL — get from Server Settings > Integrations > Webhooks
# If set, a message is posted when all providers fail simultaneously.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Batch 2-6 tuning (all optional, sensible defaults apply) ─────────────────

# Try alternate models within the same provider before falling back to the
# next provider (default: true).
# MODEL_FALLBACK_ENABLED=true

# Per-provider max_tokens hard cap — requests above this are silently clamped.
# Defaults: gemini=8192 groq=8192 openrouter=4096 cloudflare=4096 sambanova=8192 cohere=4096 mistral=8192
# MAX_TOKENS_CAP_GEMINI=8192
# MAX_TOKENS_CAP_GROQ=8192
# MAX_TOKENS_CAP_OPENROUTER=4096
# MAX_TOKENS_CAP_CLOUDFLARE=4096
# MAX_TOKENS_CAP_SAMBANOVA=8192
# MAX_TOKENS_CAP_COHERE=4096
# MAX_TOKENS_CAP_MISTRAL=8192

# Known free-tier request budgets used to auto-deprioritize a provider before
# it gets hit with a real 429. Defaults: gemini=1500/day groq=14400/day
# cloudflare=10000/day sambanova=48000/day cohere=1000/month (openrouter/mistral unlimited/unknown).
# BUDGET_GEMINI=1500
# BUDGET_GROQ=14400
# BUDGET_CLOUDFLARE=10000
# BUDGET_SAMBANOVA=48000
# BUDGET_COHERE=1000
# Fraction of budget at which a provider is deprioritized (default: 0.9 = 90%).
# BUDGET_DEPRIORITIZE_THRESHOLD=0.9

# Provider aliases — use semantic names in `providers: [...]` instead of
# hardcoding a specific provider, e.g. providers: ["fast"].
# ALIAS_FAST=groq
# ALIAS_SMART=gemini

# Input sanitization — max prompt length and API-key redaction before a
# prompt leaves the process.
# MAX_PROMPT_CHARS=32000
# REDACT_API_KEYS_IN_PROMPT=true

# Soft-fail a 200 OK response that looks empty, truncated, or like a
# boilerplate refusal, and try the next model/provider instead (default: false).
# QUALITY_SCORING_ENABLED=true

# Auto-detect the user's prompt language and nudge the model to reply in kind
# (default: false).
# MULTI_LANGUAGE_SYSTEM_PROMPT=true

# Append extra system-prompt text for a specific provider, e.g. to normalize
# behavior across models.
# SYSTEM_INJECT_GROQ=Respond concisely.
# SYSTEM_INJECT_CLOUDFLARE=Respond concisely.

# Comma-separated list of providers to force-fail with a simulated 429 —
# useful for testing the fallback chain without burning real quota.
# SIMULATE_FAILURES=gemini,groq

# Web dashboard — live provider status at http://localhost:<port>
# DASHBOARD_ENABLED=true
# DASHBOARD_PORT=4319

# OpenTelemetry-style tracing — spans are logged to stderr, or POSTed to an
# OTLP/Jaeger HTTP collector if OTEL_EXPORTER_URL is set.
# TRACING_ENABLED=true
# OTEL_EXPORTER_URL=http://localhost:4318/v1/traces

# Background warm-up pool — pings configured providers periodically so the
# first real request doesn't pay a cold-start penalty.
# PROVIDER_WARMUP_ENABLED=true
# PROVIDER_WARMUP_INTERVAL_MS=300000

# Directory containing chat_with_template's *.md prompt templates.
# TEMPLATES_DIR=./templates

# Cooldown state persistence file (survives server restarts).
# COOLDOWN_STATE_PATH=./cooldown-state.json

# HTTP proxy mode (OpenAI-compatible endpoint for IDEs and CLI tools)
# Run with: npm run start:http
# Point Cursor/Antigravity/Kiro/opencode/Claude Code/etc. "custom OpenAI API
# base URL" or *_BASE_URL env var at http://localhost:PORT/v1 — see
# IDE_SETUP.md for per-tool instructions.
# PORT=8787
